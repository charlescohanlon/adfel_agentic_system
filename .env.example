# TODO: you need to copy this into a .env file and fill it in to setup

# Azure OpenAI — used by every agent (Participant, Guardian, Lab Companion).
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<key>
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Azure AI Search — used by the Lab Companion's RAG retriever. Optional;
# leave blank to run without retrieval.
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_NAME=

# Single-user prototype identity.
STUDENT_ID=default-student
LAB_ID=default-lab
COURSE_ID=CSC580

# Optional knobs.
LOG_LEVEL=INFO
RAG_TOP_N=3
HISTORY_KEEP_TURNS=6
VERIFIER_MAX_RETRIES=2
