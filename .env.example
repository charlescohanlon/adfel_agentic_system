# TODO: you need to copy this into a .env file and fill it in to setup

# Azure OpenAI — used by every agent (Participant, Guardian, Lab Companion).
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<key>
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Azure AI Search — used by the Lab Companion's RAG retriever. Optional;
# leave blank to run without retrieval.
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_NAME=
AZURE_SEARCH_ADMIN_KEY=
AZURE_SEARCH_INDEXER_NAME=rag-x80-indexer

# Azure Blob Storage — used by the instructor upload endpoint. Optional;
# leave blank to disable file uploads.
AZURE_BLOB_CONNECTION_STRING=
AZURE_BLOB_CONTAINER_NAME=cscx80container

# Single-user prototype identity. Used as a fallback when no per-session
# student_id is set; multi-tenant deployments pass student_id per session.
STUDENT_ID=default-student
LAB_ID=default-lab
COURSE_ID=CSC580

# Multi-tenant storage roots.
DATA_ROOT=data
SYSTEM_DB_PATH=data/system.db

# Auth — Cal Poly CAS SSO. The browser-facing client redirects to CAS; the
# server back-channel-validates the ticket and mints a session JWT.
#
# TWO SECRETS, different trust boundaries — set BOTH (use long random values):
#   CHAINLIT_AUTH_SECRET  signs Chainlit's own session (client; required once
#                         any auth callback is enabled)
#   SESSION_JWT_SECRET    signs the server's API token the client carries as
#                         Authorization: Bearer (server; 32+ bytes)
CHAINLIT_AUTH_SECRET=
SESSION_JWT_SECRET=
SESSION_JWT_TTL=28800

# CAS_BASE_URL is Cal Poly's CAS base (provided by ITS after registration),
# e.g. https://cas.calpoly.edu/cas. CAS_SERVICE_URL is THIS app's public
# callback — it must match what ITS registers byte-for-byte, no trailing
# slash, e.g. https://<client-host>/login/cas/callback.
CAS_BASE_URL=
CAS_SERVICE_URL=
# When CAS omits the email attribute, the server synthesizes <netid>@<domain>.
# Enroll students by that same address or first-login late-binding 401s.
CAS_EMAIL_DOMAIN=calpoly.edu
# Mark the client's session cookie Secure (HTTPS only). Leave blank for local
# http://localhost or the browser silently drops the cookie.
ADFEL_COOKIE_SECURE=

# ADFEL_ADMIN_EMAIL is bootstrapped as the admin user on first boot and binds
# to a netid on that user's first CAS login.
ADFEL_ADMIN_EMAIL=

# Local dev WITHOUT a live Cal Poly IdP: set CAS_MOCK=1 on BOTH client and
# server to run the real redirect→ticket→validate→JWT→cookie flow against a
# fixed mock netid. Recommended local path.
CAS_MOCK=

# Dev bypass — set to 1 to skip auth entirely and impersonate ADFEL_DEV_USER_ID
# (or the bootstrapped admin). Coarser than CAS_MOCK; the server ignores tokens.
# Leave blank in production.
ADFEL_DEV_AUTH_BYPASS=
ADFEL_DEV_USER_ID=

# Optional knobs.
LOG_LEVEL=INFO
RAG_TOP_N=3
HISTORY_KEEP_TURNS=6
VERIFIER_MAX_RETRIES=2
